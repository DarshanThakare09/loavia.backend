{
  "name": "loavia-backend",
  "version": "1.0.0",
  "description": "Production-grade backend foundation for LOAVIA storefront",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx nodemon --watch src --ext ts --exec npx ts-node src/server.ts",
    "build": "npx tsc",
    "start": "node dist/server.js",
    "lint": "npx eslint src/**/*.ts",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "test:concurrency": "npx ts-node src/utils/testConcurrency.ts",
    "test:security": "npx ts-node src/utils/testHardening.ts",
    "test:all": "npx ts-node src/utils/runAllTests.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "razorpay": "^2.9.6",
    "redis": "^4.6.13",
    "resend": "^6.14.0",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.0",
    "prisma": "^5.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
}
